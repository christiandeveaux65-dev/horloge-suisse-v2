# ============================================================================
#  L'Horloge Suisse v2 — Bot de trading crypto multi-stratégie (Arbitrum)
#  Fichier d'exemple. Copiez-le en `.env` et renseignez vos valeurs.
#  cp .env.example .env
# ============================================================================

# ---------------------------------------------------------------------------
# BASE DE DONNÉES (OBLIGATOIRE)
# ---------------------------------------------------------------------------
# URL de connexion PostgreSQL (format Prisma).
DATABASE_URL="postgresql://user:password@host:5432/nom_base?schema=public"

# ---------------------------------------------------------------------------
# WALLET / EXÉCUTION ON-CHAIN
# ---------------------------------------------------------------------------
# Clé privée du wallet de trading.
#  - SI ABSENTE  -> le bot démarre en MODE DRY-RUN (simulation, aucun fonds engagé).
#  - SI PRÉSENTE -> le bot exécute de VRAIS swaps on-chain avec de VRAIS fonds.
# ⚠️  NE JAMAIS COMMITER CETTE VALEUR. Laisser vide pour rester en dry-run.
WALLET_PRIVATE_KEY=

# RPC Arbitrum (optionnel). Défaut : https://arb1.arbitrum.io/rpc
# Recommandé en production : un endpoint privé (Alchemy, Infura, QuickNode...).
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ---------------------------------------------------------------------------
# SÉCURITÉ DES TRANSACTIONS (optionnel — valeurs par défaut sûres)
# ---------------------------------------------------------------------------
# Délai max d'attente de confirmation d'une TX (ms). Défaut : 120000 (2 min).
TX_CONFIRM_TIMEOUT_MS=120000
# Nombre max de tentatives d'envoi d'une TX (retry sur erreurs de nonce). Défaut : 3.
TX_SEND_MAX_ATTEMPTS=3

# ---------------------------------------------------------------------------
# AUTHENTIFICATION DE L'API (fortement recommandé en production)
# ---------------------------------------------------------------------------
# Hash SHA-256 de votre clé API. Les requêtes doivent envoyer l'en-tête x-api-key
# contenant la clé EN CLAIR ; le serveur compare son SHA-256 à cette valeur.
#  - SI ABSENT  -> authentification DÉSACTIVÉE (mode dev, à n'utiliser qu'en local).
# Générer un hash :  echo -n "ma-cle-secrete" | sha256sum
API_KEY_HASH=

# ---------------------------------------------------------------------------
# CORS (contrôle des origines navigateur autorisées)
# ---------------------------------------------------------------------------
# Liste blanche d'origines séparées par des virgules (ex : dashboard).
#  - SI ABSENT en production -> aucune origine navigateur autorisée (fail-closed).
#  - En développement -> '*' autorisé pour faciliter les tests.
CORS_ORIGIN=https://mon-dashboard.exemple.app

# ---------------------------------------------------------------------------
# LLM (Strategist) — renseigné automatiquement par la plateforme Abacus.
# ---------------------------------------------------------------------------
# Clé d'accès aux APIs LLM (utilisée par le module Strategist).
#  - SI ABSENTE -> le Strategist retombe sur son analyse déterministe (sans LLM).
ABACUSAI_API_KEY=

# ---------------------------------------------------------------------------
# ENVIRONNEMENT
# ---------------------------------------------------------------------------
# 'production' active les protections strictes (CORS fail-closed, etc.).
NODE_ENV=production

# APP_ORIGIN est fourni automatiquement par la plateforme de déploiement.
