# ─────────────────────────────────────────────────────────────
# Dashboard NextJS — L'Horloge Suisse v2
# Variables d'environnement (copier vers .env.local)
# ─────────────────────────────────────────────────────────────

# Base de données PostgreSQL PARTAGÉE avec le bot (même instance).
# Fournie par Abacus.AI / shared_db_params lors de la création de l'app.
DATABASE_URL="postgresql://user:password@host:5432/nom_base?schema=public"

# ─── Connexion au bot (CÔTÉ SERVEUR UNIQUEMENT) ───
# URL publique du service bot déployé (sans slash final).
BOT_API_URL=https://mon-bot-horloge-suisse.abacusai.app
# Clé API EN CLAIR attendue par le bot dans l'en-tête x-api-key.
# NE JAMAIS préfixer par NEXT_PUBLIC_ : cette clé ne doit JAMAIS atteindre le client.
BOT_API_KEY=

# ─── Authentification du dashboard ───
# URL publique du dashboard (ex : https://dashboard.exemple.app)
NEXTAUTH_URL=http://localhost:3000
# Secret de session (générer : openssl rand -base64 32)
NEXTAUTH_SECRET=
# PIN d'entrée vérifié CÔTÉ SERVEUR (exactement 6 chiffres)
DASHBOARD_PIN=

# INTERDIT : ne PAS définir NEXT_PUBLIC_BOT_API_KEY ni NEXT_PUBLIC_BOT_API_URL.
# Toute variable NEXT_PUBLIC_* est exposée au navigateur → fuite de secret.
